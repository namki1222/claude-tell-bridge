#!/bin/bash
# tell — session-to-session messaging bridge for Claude Code over tmux
#
# 메시징:
#   tell <세션> <역할> "<메시지>"        요청 전송 (6자리 상관키 KEY 자동 생성·출력)
#   tell -r <KEY> <세션> <역할> "<메시지>"  응답 전송 (받은 요청의 KEY 그대로)
# 관리:
#   tell ws [<세션>]                     워크스페이스 부트스트랩/접속 (설정: workspaces.conf)
#   tell init                            셋업 마법사 — 허브(선택) → 프로젝트/역할/디렉터리
#   tell adopt                           떠 있는 tmux 세션을 브릿지에 편입 (재시작 불필요)
#   tell hub                             총괄 관리(허브) 세션을 나중에 추가
#   tell list                            주소록 — 말 걸 수 있는 세션:역할 + 규약 여부
#   tell rm <세션>                       세션 정리 — tmux 종료 + 설정에서 제거 (각각 확인)
#   tell doctor                          환경 점검
#
# 동작 원리:
#   - 대상 = tmux "세션 이름" + "패널 제목(=역할)". 메시지는 send-keys로 상대 입력창에 직접 입력됨.
#   - 요청 헤더: [세션 요청 - KEY from 보낸세션/보낸역할]  /  응답 헤더: [세션 응답 - KEY from ...]
#   - 받는 쪽 Claude는 CLAUDE.md 규약(templates/ 참고)에 따라 작업 후 `tell -r KEY ...`를 실행해 응답.
#   - 대상이 작업 중이어도 전송됨(Claude Code가 입력을 큐잉). 입력창에 미제출 텍스트가 있으면
#     덮어쓰기 방지를 위해 10초 대기 후 재시도(최대 3회).
#
# ⚠️ 보안: send-keys 기반이라 같은 tmux 서버 사용자는 누구나 주입 가능. 비밀번호/토큰은 절대 tell로 보내지 말 것.
# 종료코드: 0 전송 / 1 대상없음 / 2 인자오류

set -u
CONFIG_DIR="${TELL_CONFIG_DIR:-$HOME/.config/claude-tell-bridge}"
WS_CONF="$CONFIG_DIR/workspaces.conf"

# ── 스크립트 실제 위치(심링크 해제) → templates/ 찾기 ──────────────────────────
resolve_self() {
  local src="$0"
  while [ -L "$src" ]; do
    local dir; dir=$(cd -P "$(dirname "$src")" && pwd)
    src=$(readlink "$src")
    case "$src" in /*) ;; *) src="$dir/$src" ;; esac
  done
  cd -P "$(dirname "$src")" && pwd
}
SELF_DIR=$(resolve_self)
TEMPLATE_DIR="$SELF_DIR/../templates"

# ══════════════════════════════════════════════════════════════════════════════
# 서브커맨드
# ══════════════════════════════════════════════════════════════════════════════

cmd_doctor() {
  local ok=0
  echo "── tell doctor ──"
  if command -v tmux >/dev/null 2>&1; then echo "✅ tmux $(tmux -V | awk '{print $2}')"; else echo "❌ tmux 없음 — brew install tmux"; ok=1; fi
  if command -v claude >/dev/null 2>&1; then echo "✅ claude $(claude --version 2>/dev/null | awk '{print $1}')"; else echo "⚠️  claude CLI 없음 — 메시징은 되지만 받는 쪽 AI가 없음"; fi
  if [ -n "${TMUX:-}" ]; then echo "✅ tmux 세션 안에서 실행 중 (발신자 헤더 자동)"; else echo "ℹ️  tmux 밖 — 발신자(from) 헤더 없이 전송됨"; fi
  if [ -f "$WS_CONF" ]; then echo "✅ 워크스페이스 설정: $WS_CONF ($(grep -cvE '^[[:space:]]*(#|$)' "$WS_CONF" 2>/dev/null || echo 0)줄)"; else echo "ℹ️  워크스페이스 설정 없음 — 'tell init' 또는 'tell adopt'로 생성"; fi
  [ -f "$TEMPLATE_DIR/CLAUDE-section-role.md" ] && echo "✅ 템플릿: $TEMPLATE_DIR" || echo "⚠️  템플릿 폴더 못 찾음: $TEMPLATE_DIR"
  echo "ℹ️  주의: 입력창 감지는 Claude Code 프롬프트 렌더링(❯)을 읽습니다. CLI 대개편 시 점검 필요."
  return $ok
}

append_role_template() { # $1=dir  $2=session  $3=roles(공백구분)  $4=hub_session  $5=hub_role
  local dir="$1" session="$2" roles="$3" hub_s="$4" hub_r="$5"
  local f="$dir/CLAUDE.md" t="$TEMPLATE_DIR/CLAUDE-section-role.md"
  [ -f "$t" ] || { echo "  ⚠️ 템플릿 없음: $t"; return 1; }
  if [ -f "$f" ] && grep -q '세션 요청 - KEY' "$f" 2>/dev/null; then
    echo "  ↷ 이미 규약 있음: $f (건너뜀)"; return 0
  fi
  mkdir -p "$dir"
  { [ -f "$f" ] && echo ""; sed -e "s/{{SESSION}}/$session/g" -e "s/{{ROLES}}/$roles/g" \
        -e "s/{{HUB_SESSION}}/$hub_s/g" -e "s/{{HUB_ROLE}}/$hub_r/g" "$t" \
    | sed -e 's# (보통 발신자는 허브 `/`)##'; } >> "$f"   # 허브 없이 쓰면 허브 문구 제거
  echo "  ✍️  규약 추가됨: $f"
}

make_hub() { # 허브 세션 등록 + 허브 CLAUDE.md 생성. 성공 시 HUB/HUBR 설정됨
  printf "  허브 세션 이름 [hub]: "; read -r HUB; HUB=${HUB:-hub}
  printf "  허브 역할(패널 이름) [hub]: "; read -r HUBR; HUBR=${HUBR:-hub}
  printf "  허브 작업 디렉터리 [~/tell-hub]: "; read -r HUBD; HUBD=${HUBD:-$HOME/tell-hub}; HUBD=${HUBD/#\~/$HOME}
  echo "$HUB|$HUBR|$HUBD" >> "$WS_CONF"; mkdir -p "$HUBD"
  if [ -f "$TEMPLATE_DIR/CLAUDE-section-hub.md" ] && ! grep -q '허브(비서)' "$HUBD/CLAUDE.md" 2>/dev/null; then
    { [ -f "$HUBD/CLAUDE.md" ] && echo ""; sed -e "s/{{HUB_SESSION}}/$HUB/g" -e "s/{{HUB_ROLE}}/$HUBR/g" "$TEMPLATE_DIR/CLAUDE-section-hub.md"; } >> "$HUBD/CLAUDE.md"
    echo "  ✍️  허브 CLAUDE.md 생성: $HUBD/CLAUDE.md"
  fi
}

cmd_init() {
  echo "── tell init — 셋업 마법사 ──"
  echo "  개념: 세션 = 프로젝트 / 패널(역할) = 그 프로젝트에 상주하는 Claude 하나"
  mkdir -p "$CONFIG_DIR"
  HUB=""; HUBR=""
  echo ""
  echo "[1/2] 총괄 관리(허브) 세션 (선택)"
  echo "      허브란? 여러 프로젝트를 대신 지휘해주는 '비서' Claude 세션입니다."
  echo "      예) 허브에게 \"서버에 API 추가하고 웹에 버튼 달아줘\" 한 마디"
  echo "          → 허브가 서버·웹 세션에 각각 시키고, 끝나면 결과를 모아 보고합니다."
  echo "      없어도 됩니다 — 세션끼리는 직접 대화 가능. 나중에 'tell hub'로 추가할 수 있습니다."
  printf "총괄 관리 세션을 만들까요? [y/N]: "; read -r MK
  if [ "$MK" = "y" ] || [ "$MK" = "Y" ]; then
    make_hub
  else
    echo "  ⤼ 건너뜀 (나중에 추가: tell hub)"
  fi
  echo ""
  echo "[2/2] 프로젝트 등록"
  echo "      프로젝트(세션) 하나에 역할(패널)을 여러 개 둘 수 있습니다. 예: 서버·웹·앱"
  while :; do
    printf "프로젝트 이름 = 세션 이름 (빈 값 = 완료): "; read -r S; [ -z "$S" ] && break
    while :; do
      printf "  이 Claude의 역할 = 패널 이름 (예: 서버, 빈 값 = 다음 프로젝트): "; read -r R; [ -z "$R" ] && break
      printf "  '%s' 담당 디렉터리: " "$R"; read -r D; D=${D/#\~/$HOME}
      [ -z "$D" ] && { echo "  ⚠️ 디렉터리는 필수"; continue; }
      echo "$S|$R|$D" >> "$WS_CONF"
      append_role_template "$D" "$S" "$R" "$HUB" "$HUBR"
    done
  done
  echo ""
  echo "✅ 저장: $WS_CONF"
  echo "다음 단계:"
  [ -n "$HUB" ] && echo "  tell ws $HUB           # 허브 띄우기"
  echo "  tell ws <프로젝트>      # 프로젝트 띄우기 (패널 분할 + claude 자동 실행)"
  echo "  tell list              # 말 걸 수 있는 주소 확인"
}

cmd_adopt() {
  echo "── tell adopt — 떠 있는 tmux 세션을 브릿지에 편입 (재시작 불필요) ──"
  command -v tmux >/dev/null 2>&1 || { echo "tmux 없음"; exit 1; }
  tmux ls >/dev/null 2>&1 || { echo "떠 있는 tmux 세션 없음 — 'tell init'을 쓰세요"; exit 1; }
  mkdir -p "$CONFIG_DIR"
  echo ""
  echo "[1/2] 총괄 관리(허브) 세션 (선택)"
  echo "      허브란? 여러 프로젝트를 대신 지휘해주는 '비서' Claude 세션 — 일을 나눠 시키고 결과를 모아 보고."
  echo "      이미 허브로 쓰는 세션이 있으면 '세션 역할'로 지정 (예: hub hub)."
  echo "      없으면 그냥 엔터 — 나중에 'tell hub'로 추가할 수 있습니다."
  printf "허브 지정 [엔터 = 건너뜀]: "; read -r HUB HUBR _junk
  HUBR=${HUBR:-$HUB}
  [ -z "$HUB" ] && echo "  ⤼ 건너뜀 (나중에 추가: tell hub)"
  echo ""
  echo "[2/2] 패널 스캔 — 각 패널(Claude)을 어떤 역할(주소)로 쓸지 정합니다."
  tmux list-panes -a -F '#{session_name}|#{pane_id}|#{pane_title}|#{pane_current_path}' | while IFS='|' read -r S P T D; do
    echo ""
    echo "▸ 프로젝트(세션) '$S' · 패널 \"$T\" · 디렉터리 $D"
    printf "  이 Claude의 역할 이름? [엔터=\"%s\" 유지 / 새 이름 입력 / s=건너뜀]: " "$T"; read -r ANS </dev/tty
    [ "$ANS" = "s" ] && { echo "  ⤼ 건너뜀"; continue; }
    ROLE=${ANS:-$T}
    [ "$ROLE" != "$T" ] && tmux select-pane -t "$P" -T "$ROLE"
    echo "$S|$ROLE|$D" >> "$WS_CONF"
    append_role_template "$D" "$S" "$ROLE" "$HUB" "$HUBR"
    printf "  지금 이 패널의 Claude에 규약 로드+핑퐁 메시지 보낼까? [y/N]: "; read -r GO </dev/tty
    if [ "$GO" = "y" ]; then
      "$0" "$S" "$ROLE" "CLAUDE.md가 갱신됐어. Read로 다시 읽고 세션 협업(tell) 규약을 숙지해. 확인되면 받은 키로 tell -r 로 '퐁 정상' 한 줄만 응답해줘."
    fi
  done
  echo ""
  echo "✅ 편입 완료. 설정: $WS_CONF   (확인: tell list)"
}

cmd_hub() {
  echo "── tell hub — 총괄 관리(허브) 세션 추가 ──"
  echo "  허브란? 여러 프로젝트를 대신 지휘해주는 '비서' Claude 세션입니다."
  echo "  예) 허브에게 \"서버에 API 추가하고 웹에 버튼 달아줘\" → 알아서 나눠 시키고 취합 보고."
  mkdir -p "$CONFIG_DIR"
  make_hub
  echo ""
  echo "✅ 등록 완료. 다음: tell ws $HUB   (참고: 이후 init/adopt로 등록하는 프로젝트 규약에 이 허브 주소가 반영됩니다)"
}

cmd_list() {
  command -v tmux >/dev/null 2>&1 || { echo "tmux 없음"; exit 1; }
  tmux ls >/dev/null 2>&1 || { echo "떠 있는 tmux 세션 없음 — 'tell ws <세션>' 으로 띄우세요"; exit 0; }
  echo "── 주소록 — 사용법: tell <세션> <역할> \"<메시지>\" ──"
  printf '%-16s %-16s %-6s %-8s %s\n' "세션" "역할" "규약" "실행" "디렉터리"
  tmux list-panes -a -F '#{session_name}|#{pane_title}|#{pane_current_path}|#{pane_current_command}' \
  | while IFS='|' read -r S T D C; do
      # 규약 체크: Claude Code는 상위 폴더 CLAUDE.md도 상속하므로 조상 디렉터리까지 올라가며 확인
      conv="❌"; dir="$D"
      while [ -n "$dir" ] && [ "$dir" != "/" ]; do
        if [ -f "$dir/CLAUDE.md" ] && grep -q '세션 요청 - KEY' "$dir/CLAUDE.md" 2>/dev/null; then conv="✅"; break; fi
        dir=$(dirname "$dir")
      done
      case "$C" in claude|node|[0-9]*.[0-9]*) run="claude" ;; *) run="$C" ;; esac   # claude CLI는 버전 문자열로 보고되기도 함
      printf '%-16s %-16s %-6s %-8s %s\n' "$S" "$T" "$conv" "$run" "$D"
    done
  echo ""
  echo "규약 ❌ = 그 디렉터리 CLAUDE.md에 응답 규약 없음 → 'tell adopt'로 편입하면 응답이 돌아옵니다."
}

cmd_rm() {
  local NAME="${1:-}"
  if [ -z "$NAME" ]; then
    echo "usage: tell rm <세션>"
    echo "── 실행 중 세션 ──"; tmux ls 2>/dev/null || echo "(없음)"
    if [ -f "$WS_CONF" ]; then
      echo "── 설정된 세션 ──"; grep -vE '^[[:space:]]*(#|$)' "$WS_CONF" | awk -F'|' '{print $1}' | sort -u
    fi
    exit 2
  fi
  local did=0
  if tmux has-session -t "=$NAME" 2>/dev/null; then
    local n; n=$(tmux list-panes -t "=$NAME" 2>/dev/null | wc -l | tr -d ' ')
    printf "tmux 세션 '%s'(패널 %s개)를 종료할까요? 진행 중인 Claude 대화가 닫힙니다 [y/N]: " "$NAME" "$n"; read -r A
    if [ "$A" = "y" ] || [ "$A" = "Y" ]; then tmux kill-session -t "=$NAME" && echo "  ✅ tmux 세션 종료됨"; did=1; fi
  else
    echo "  ℹ️ 실행 중인 tmux 세션 '$NAME' 없음"
  fi
  if [ -f "$WS_CONF" ] && LC_ALL=C awk -F'|' -v s="$NAME" '$1==s{found=1} END{exit !found}' "$WS_CONF"; then
    printf "설정(workspaces.conf)의 '%s' 항목도 제거할까요? [y/N]: " "$NAME"; read -r B
    if [ "$B" = "y" ] || [ "$B" = "Y" ]; then
      cp "$WS_CONF" "$WS_CONF.bak"
      LC_ALL=C awk -F'|' -v s="$NAME" '$1!=s' "$WS_CONF.bak" > "$WS_CONF"
      echo "  ✅ 설정에서 제거됨 (백업: $WS_CONF.bak)"; did=1
    fi
  fi
  [ "$did" = "0" ] && echo "  (변경 없음)"
  return 0
}

cmd_ws() {
  local NAME="${1:-}"
  if [ ! -f "$WS_CONF" ]; then echo "설정 없음: $WS_CONF — 'tell init' 먼저"; exit 1; fi
  if [ -z "$NAME" ]; then
    echo "── 실행 중 ──"; tmux ls 2>/dev/null || echo "(없음)"
    echo "── 설정된 워크스페이스 ──"
    grep -vE '^[[:space:]]*(#|$)' "$WS_CONF" | awk -F'|' '{print $1}' | sort -u
    exit 0
  fi
  if ! tmux has-session -t "=$NAME" 2>/dev/null; then
    local p
    # 주의: 루프 안 tmux 호출에 </dev/null — stdin(설정 라인)을 삼켜 다음 패널을 건너뛰는 버그 방지
    grep -vE '^[[:space:]]*(#|$)' "$WS_CONF" | LC_ALL=C awk -F'|' -v s="$NAME" '$1==s' | while IFS='|' read -r S R D; do
      D=${D/#\~/$HOME}
      if [ ! -d "$D" ]; then echo "⚠️ 디렉터리 없음: $D (건너뜀)"; continue; fi
      if ! tmux has-session -t "=$NAME" 2>/dev/null; then
        p=$(tmux new-session -d -P -F '#{pane_id}' -s "$NAME" -c "$D" </dev/null)
      else
        # split 타깃은 세션명이 아니라 패널이어야 함 → 직전 패널 id 사용
        p=$(tmux split-window -h -P -F '#{pane_id}' -t "$p" -c "$D" </dev/null)
      fi
      tmux select-pane -t "$p" -T "$R" </dev/null
      tmux send-keys -t "$p" "claude" Enter </dev/null
    done
    tmux has-session -t "=$NAME" 2>/dev/null || { echo "알 수 없는 워크스페이스: $NAME"; exit 1; }
    tmux select-layout -t "=$NAME" tiled 2>/dev/null
  fi
  if [ -n "${TMUX:-}" ]; then tmux switch-client -t "=$NAME"; else tmux attach -t "=$NAME"; fi
}

case "${1:-}" in
  init)   shift; cmd_init "$@";   exit $? ;;
  adopt)  shift; cmd_adopt "$@";  exit $? ;;
  hub)    shift; cmd_hub "$@";    exit $? ;;
  list)   shift; cmd_list;        exit $? ;;
  rm)     shift; cmd_rm "${1:-}"; exit $? ;;
  ws)     shift; cmd_ws "${1:-}"; exit $? ;;
  doctor) shift; cmd_doctor;      exit $? ;;
esac

# ══════════════════════════════════════════════════════════════════════════════
# 코어: 메시지 전송
# ══════════════════════════════════════════════════════════════════════════════

REPLY=0; KEY=""
if [ "${1:-}" = "-r" ]; then
  REPLY=1; KEY="${2:-}"; shift 2 2>/dev/null
  if [ -z "$KEY" ]; then echo "usage: tell -r <KEY> <세션> <역할> <메시지>"; exit 2; fi
fi

SESSION="${1:-}"; ROLE="${2:-}"; shift 2 2>/dev/null; MSG="$*"
if [ -z "$SESSION" ] || [ -z "$ROLE" ] || [ -z "$MSG" ]; then
  echo "usage: tell [-r <KEY>] <세션> <역할> <메시지>   |   tell init|adopt|hub|list|rm|ws|doctor"; exit 2
fi

# LC_ALL=C: macOS awk가 일부 로케일에서 비ASCII 문자열 == 비교를 깨뜨리는 버그 회피(바이트 단위 비교)
PANE=$(tmux list-panes -t "=$SESSION" -F "#{pane_id}	#{pane_title}" 2>/dev/null \
  | LC_ALL=C awk -F'\t' -v r="$ROLE" '$2==r{print $1; exit}')
if [ -z "$PANE" ]; then
  echo "[tell] 대상 패널 없음: $SESSION:$ROLE"
  echo "       (가용) $(tmux list-panes -t "=$SESSION" -F '#{pane_title}' 2>/dev/null | paste -sd' ' -)"
  exit 1
fi

# 발신자(세션/역할) 자동 감지 — 받는 쪽이 '어디로 tell -r 할지' 알게 하는 핵심
SRC=""
if [ -n "${TMUX_PANE:-}" ]; then
  src_ses=$(tmux display-message -p -t "$TMUX_PANE" '#{session_name}' 2>/dev/null)
  src_role=$(tmux display-message -p -t "$TMUX_PANE" '#{pane_title}' 2>/dev/null)
  [ -n "$src_ses" ] && [ -n "$src_role" ] && SRC=" from ${src_ses}/${src_role}"
fi

if [ "$REPLY" = "1" ]; then
  MSG="[세션 응답 - $KEY$SRC] $MSG"
else
  KEY=$(openssl rand -hex 3 2>/dev/null)
  [ -z "$KEY" ] && KEY=$(printf '%06x' $(( ((RANDOM<<8) ^ RANDOM) & 0xffffff )))
  MSG="[세션 요청 - $KEY$SRC] $MSG"
fi

# 입력창 미제출 텍스트(사용자 타이핑) 감지 → 덮어쓰기 방지 대기
has_unsubmitted_input() {
  local line
  line=$(tmux capture-pane -t "$PANE" -p 2>/dev/null | grep -E "^❯" | tail -1 | sed -E 's/^❯[[:space:]]*//; s/[[:space:]]+$//')
  [ -n "$line" ] && return 0
  return 1
}
for i in 1 2 3; do
  has_unsubmitted_input || break
  echo "[tell] 입력창에 미제출 텍스트 감지 — 10초 후 재시도 ($i/3)"
  sleep 10
done

tmux send-keys -t "$PANE" -l "$MSG"
sleep 0.6
tmux send-keys -t "$PANE" Enter
sleep 0.8
head="$(printf '%s' "$MSG" | cut -c1-14)"
if tmux capture-pane -t "$PANE" -p 2>/dev/null | grep -qF "❯ $head"; then
  tmux send-keys -t "$PANE" Enter
fi

if [ "$REPLY" = "1" ]; then
  echo "[tell] 응답 전송 완료 → $SESSION:$ROLE ($PANE)  (KEY=$KEY)"
else
  echo "[tell] 요청 전송 완료 → $SESSION:$ROLE ($PANE)"
  echo "[tell] 요청 KEY=$KEY  ← 이 KEY의 [세션 응답 - $KEY] 를 기다리세요"
fi
